# WebSocket bridge URL (defaults to ws://localhost:9090 if not set)
VITE_WS_URL=ws://localhost:9090

# Optional Twilio-compatible webhook for T=TODO ghost SMS broadcast payloads
VITE_TWILIO_SMS_WEBHOOK_URL=

# Figma API Configuration (for design_machine_state sync)
# Get your token from: https://www.figma.com/developers/api#access-tokens
VITE_FIGMA_ACCESS_TOKEN=

# Your Figma file key (from the URL: figma.com/file/{FILE_KEY}/...)
VITE_FIGMA_FILE_KEY=

# Antigravity sync interval in milliseconds (default: 30000 = 30s)
VITE_ANTIGRAVITY_SYNC_INTERVAL=30000
